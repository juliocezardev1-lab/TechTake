                <div class="svc-num">01</div>
                <div class="svc-body">
                    <h3>Filmagem com Drone</h3>
                    <!-- DESCRIÇÃO DO SERVIÇO 1 -->
                    <p>Captação aérea com drones de última geração, resolução até 6K, estabilização de 3 eixos e voo
                        autorizado pelo DECEA. Ideal para eventos, imóveis, obras e produções cinematográficas.</p>
                </div>
                <div class="svc-tags">
                    <!-- TAGS DO SERVIÇO 1 — edite conforme necessário -->
                    <span class="tag">Drone</span>
                    <span class="tag">4K / 6K</span>
                    <span class="tag">Externo</span>
                </div>
            </div>

            <!-- SERVIÇO 2 ─────────────────────────────────── -->
            <div class="svc-row reveal">
                <div class="svc-num">02</div>
                <div class="svc-body">
                    <h3>Fotografia Profissional</h3>
                    <!-- DESCRIÇÃO DO SERVIÇO 2 -->
