<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contratar Serviços - Buxa Audio Visual</title>
    <style>
        :root {
            --clr-bg: #0b0e14;
            --clr-surface: #121620;
            --clr-border: #1e2533;
            --clr-accent1: #00c6ff;
            --clr-accent2: #0072ff;
            --clr-accent3: #00ffd5;
            --clr-text: #e8edf5;
            --clr-muted: #6b7a99;
            --font-display: 'Bebas Neue', sans-serif;
            --font-body: 'Exo 2', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
            font-family: var(--font-body);
            background: var(--clr-bg);
            color: var(--clr-text);
            line-height: 1.6;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            padding: 1rem 2rem;
            background: rgba(11, 14, 20, 0.92);
            border-bottom: 1px solid var(--clr-border);
            backdrop-filter: blur(12px);
        }

        .navbar h1 {
            font-family: var(--font-display);
            font-size: 1.4rem;
            color: var(--clr-text);
        }

        .nav-right {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .nav-right a {
            color: var(--clr-muted);
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            transition: color 0.25s ease;
        }

        .nav-right a:hover,
        .nav-right a.active {
            color: var(--clr-accent1);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 9rem 1.5rem 4rem;
        }

        .header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .header h1 {
            font-family: var(--font-display);
            font-size: clamp(2.8rem, 5vw, 4.5rem);
            letter-spacing: 0.04em;
            margin-bottom: 1rem;
        }

        .header p {
            color: var(--clr-muted);
            font-size: 1rem;
            max-width: 720px;
            margin: 0 auto;
        }

        .tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: center;
            margin-bottom: 3rem;
        }

        .tab-btn {
            padding: 0.95rem 1.8rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--clr-border);
            color: var(--clr-text);
            border-radius: 999px;
            cursor: pointer;
            font-weight: 700;
            transition: all 0.25s ease;
        }

        .tab-btn.active {
            background: var(--clr-accent1);
            color: var(--clr-bg);
            border-color: var(--clr-accent1);
        }

        .tab-btn:hover {
            color: var(--clr-accent1);
            border-color: var(--clr-accent1);
        }

        .content {
            display: none;
        }

        .content.active {
            display: block;
        }

        .packages-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .package-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--clr-border);
            border-radius: 1rem;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            transition: transform 0.3s ease, border-color 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .package-card:hover {
            transform: translateY(-6px);
            border-color: rgba(0, 198, 255, 0.35);
        }

        .package-header {
            background: linear-gradient(135deg, rgba(0, 198, 255, 0.95), rgba(0, 114, 255, 0.95));
            color: white;
            padding: 1.4rem 1.5rem;
            text-align: center;
        }

        .package-header h3 {
            font-size: 1.4rem;
            margin-bottom: 0.2rem;
        }

        .package-body {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            flex-grow: 1;
        }

        .package-info {
            color: var(--clr-text);
            font-size: 0.95rem;
            line-height: 1.75;
        }

        .info-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 700;
            color: var(--clr-accent1);
        }

        .info-value {
            color: var(--clr-muted);
            margin-left: 0.4rem;
        }

        .price-section {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 0.85rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 1rem;
        }

        .price-range {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--clr-text);
            text-align: center;
        }

        .price-label {
            font-size: 0.85rem;
            color: var(--clr-muted);
            text-align: center;
            margin-top: 0.4rem;
        }

        .btn-contratar {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            padding: 1rem 1.4rem;
            border-radius: 0.85rem;
            border: 1px solid transparent;
            background: linear-gradient(135deg, var(--clr-accent1), var(--clr-accent2));
            color: var(--clr-bg);
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.25s ease, filter 0.25s ease;
            margin-top: auto;
        }

        .btn-contratar:hover {
            transform: translateY(-1px);
            filter: brightness(1.05);
        }

        .no-content,
        .loading {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--clr-border);
            border-radius: 1rem;
            padding: 2.5rem;
            text-align: center;
            color: var(--clr-text);
        }

        .loading {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(255, 255, 255, 0.12);
            border-top: 4px solid var(--clr-accent1);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .footer {
            background: rgba(11, 14, 20, 0.95);
            border-top: 1px solid var(--clr-border);
            color: var(--clr-muted);
            text-align: center;
            padding: 3rem 1.5rem;
        }

        .footer h3 {
            color: var(--clr-text);
            margin-bottom: 0.75rem;
        }

        @media (max-width: 900px) {
            .container {
                padding: 8.5rem 1.25rem 3rem;
            }

            .tab-btn {
                width: 100%;
            }
        }

        @media (max-width: 680px) {
            .navbar {
                flex-direction: column;
                align-items: flex-start;
                padding: 1rem 1rem;
            }

            .nav-right {
                width: 100%;
                justify-content: flex-start;
            }

            .package-body {
                padding: 1.25rem;
            }

            .header h1 {
                font-size: 2.5rem;
            }
        }
    </style>
</head>

<body>
    <div class="navbar">
        <h1>🎥 Buxa Audio Visual</h1>
        <div class="nav-right">
            <a href="/home">Home</a>
            <a href="/servicos">Serviços</a>
            <a href="/sobre">Sobre</a>
            <a href="/contato">Contato</a>
        </div>
    </div>

    <div class="container">
        <div class="header">
            <h1>Contratar Nossos Serviços</h1>
            <p>Escolha o pacote perfeito para seu projeto audiovisual. Contamos com diferentes soluções técnicas para
                atender suas necessidades.</p>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('pacotes', this)">📦 Pacotes de Serviços</button>
            <button class="tab-btn" onclick="switchTab('drone', this)">🚁 Com Drone</button>
            <button class="tab-btn" onclick="switchTab('adicional', this)">🔒 Adicionais</button>
        </div>

        <!-- ABA DE PACOTES NORMAIS -->
        <div id="pacotes" class="content active">
            <div class="loading" id="pacotesLoading">
                <div class="spinner"></div>
                <p>Carregando pacotes...</p>
            </div>
            <div class="packages-grid" id="pacotesGrid" style="display: none;"></div>
            <div class="no-content" id="pacotesEmpty" style="display: none;">
                Nenhum pacote disponível no momento.
            </div>
        </div>

        <!-- ABA DE PACOTES COM DRONE -->
        <div id="drone" class="content">
            <div class="loading" id="droneLoading">
                <div class="spinner"></div>
                <p>Carregando pacotes com drone...</p>
            </div>
            <div class="packages-grid" id="droneGrid" style="display: none;"></div>
            <div class="no-content" id="droneEmpty" style="display: none;">
                Nenhum pacote com drone disponível no momento.
            </div>
        </div>

        <!-- ABA DE ADICIONAIS -->
        <div id="adicional" class="content">
            <div class="packages-grid">
                <div class="package-card">
                    <div class="package-header">
                        <h3>🔒 Seguro de Mídia</h3>
                    </div>
                    <div class="package-body">
                        <div class="package-info">
                            <div class="info-label">O que você ganha:</div>
                            <div class="info-value">
                                ✓ Armazenamento seguro por 30 dias<br>
                                ✓ Backup de todos os arquivos<br>
                                ✓ Recuperação imediata se necessário<br>
                                ✓ Proteção contra perda de dados
                            </div>
                        </div>

                        <div class="price-section">
                            <div class="price-range">R$ 30,00</div>
                            <div class="price-label">Taxa única</div>
                        </div>

                        <div class="package-info">
                            <div class="info-label">Descrição:</div>
                            <div class="info-value">
                                Serviço extra para garantir a total segurança dos seus materiais audiovisuais (fotos e
                                vídeos). Armazenamos seu projeto de forma segura em nossos servidores por até 30 dias
                                após o pagamento.
                            </div>
                        </div>

                        <button class="btn-contratar" onclick="contratar('Seguro de Mídia', 30)">Contratar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer">
        <h3>Pronto para começar seu projeto?</h3>
        <p>Entre em contato conosco através da página de contato ou escolha um pacote acima.</p>
        <p style="margin-top: 20px; opacity: 0.8;">© 2026 Buxa Audio Visual - Todos os direitos reservados</p>
    </div>

    <script>
        const API_URL = '/api';

        // ========================================
        // TROCAR ABAS
        // ========================================

        function switchTab(tabName, button) {
            // Esconder conteúdos
            document.querySelectorAll('.content').forEach(el => {
                el.classList.remove('active');
            });

            // Esconder botões ativos
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            // Mostrar aba selecionada
            document.getElementById(tabName).classList.add('active');
            if (button) {
                button.classList.add('active');
            }

            // Carregar dados
            if (tabName === 'pacotes') {
                loadPacotes();
            } else if (tabName === 'drone') {
                loadDrones();
            }
        }

        // ========================================
        // CARREGAR PACOTES
        // ========================================

        async function loadPacotes() {
            const grid = document.getElementById('pacotesGrid');
            const loading = document.getElementById('pacotesLoading');
            const empty = document.getElementById('pacotesEmpty');

            loading.style.display = 'block';
            grid.style.display = 'none';
            empty.style.display = 'none';

            try {
                const response = await fetch(`${API_URL}/pacotes`);
                const data = await response.json();

                if (data.pacotes && data.pacotes.length > 0) {
                    grid.innerHTML = '';
                    data.pacotes.forEach(pacote => {
                        const card = document.createElement('div');
                        card.className = 'package-card';

                        let conteudo = `
                            <div class="package-header">
                                <h3>${pacote.nome}</h3>
                            </div>
                            <div class="package-body">
                        `;

                        if (pacote.configuracao_tecnica) {
                            conteudo += `
                                <div class="package-info">
                                    <div class="info-label">Configuração Técnica:</div>
                                    <div class="info-value">${pacote.configuracao_tecnica}</div>
                                </div>
                            `;
                        }

                        if (pacote.destaque_servico) {
                            conteudo += `
                                <div class="package-info">
                                    <div class="info-label">Destaque:</div>
                                    <div class="info-value">${pacote.destaque_servico}</div>
                                </div>
                            `;
                        }

                        if (pacote.descricao) {
                            conteudo += `
                                <div class="package-info">
                                    <div class="info-label">Descrição:</div>
                                    <div class="info-value">${pacote.descricao}</div>
                                </div>
                            `;
                        }

                        conteudo += `
                                <div class="price-section">
                                    <div class="price-range">R$ ${parseFloat(pacote.investimento_min).toFixed(2)} - R$ ${parseFloat(pacote.investimento_max).toFixed(2)}</div>
                                    <div class="price-label">Valor estimado</div>
                                </div>
                                <button class="btn-contratar" onclick="contratar('${pacote.nome}', ${pacote.investimento_min})">Contratar Agora</button>
                            </div>
                        `;

                        card.innerHTML = conteudo;
                        grid.appendChild(card);
                    });

                    loading.style.display = 'none';
                    grid.style.display = 'grid';
                } else {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                }
            } catch (err) {
                console.error('Erro ao carregar pacotes:', err);
                loading.style.display = 'none';
                empty.style.display = 'block';
                empty.textContent = 'Erro ao carregar pacotes. Por favor, tente novamente.';
            }
        }

        // ========================================
        // CARREGAR DRONES
        // ========================================

        async function loadDrones() {
            const grid = document.getElementById('droneGrid');
            const loading = document.getElementById('droneLoading');
            const empty = document.getElementById('droneEmpty');

            loading.style.display = 'block';
            grid.style.display = 'none';
            empty.style.display = 'none';

            try {
                const response = await fetch(`${API_URL}/pacotes-drone`);
                const data = await response.json();

                if (data.pacotes_drone && data.pacotes_drone.length > 0) {
                    grid.innerHTML = '';
                    data.pacotes_drone.forEach(drone => {
                        const card = document.createElement('div');
                        card.className = 'package-card';

                        let conteudo = `
                            <div class="package-header">
                                <h3>🚁 Pacote com Drone</h3>
                            </div>
                            <div class="package-body">
                        `;

                        if (drone.configuracao_tecnica) {
                            conteudo += `
                                <div class="package-info">
                                    <div class="info-label">Configuração Técnica:</div>
                                    <div class="info-value">${drone.configuracao_tecnica}</div>
                                </div>
                            `;
                        }

                        if (drone.destaque_servico) {
                            conteudo += `
                                <div class="package-info">
                                    <div class="info-label">Destaque:</div>
                                    <div class="info-value">${drone.destaque_servico}</div>
                                </div>
                            `;
                        }

                        conteudo += `
                                <div class="price-section">
                                    <div class="price-range">R$ ${parseFloat(drone.investimento).toFixed(2)}</div>
                                    <div class="price-label">Investimento adicional</div>
                                </div>
                                <button class="btn-contratar" onclick="contratar('Pacote Drone', ${drone.investimento})">Contratar Agora</button>
                            </div>
                        `;

                        card.innerHTML = conteudo;
                        grid.appendChild(card);
                    });

                    loading.style.display = 'none';
                    grid.style.display = 'grid';
                } else {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                }
            } catch (err) {
                console.error('Erro ao carregar drones:', err);
                loading.style.display = 'none';
                empty.style.display = 'block';
                empty.textContent = 'Erro ao carregar pacotes com drone. Por favor, tente novamente.';
            }
        }

        // ========================================
        // CONTRATAR PACOTE
        // ========================================

        function contratar(nomePacote, preco) {
            const mensagem = `Olá! Gostaria de contratar o pacote "${nomePacote}" (Valor: R$ ${preco.toFixed(2)})`;
            const whatsappLink = `https://wa.me/?text=${encodeURIComponent(mensagem)}`;
            window.open(whatsappLink, '_blank');
        }

        // ========================================
        // INICIALIZAR
        // ========================================

        window.addEventListener('load', () => {
            loadPacotes();
        });
    </script>
</body>

</html>

.page-hero-bg {
position: absolute;
inset: -10%;
/* ══════════════════════════════════════════════════════════
IMAGEM DE FUNDO DO BANNER — PÁGINA SERVIÇOS
Substitua a URL pelo seu arquivo: ex. banner-servicos.jpg
══════════════════════════════════════════════════════════ */
background-image:
linear-gradient(to right, rgba(11, 14, 20, .85) 30%, rgba(11, 14, 20, .3) 100%),
url("https://images.unsplash.com/photo-1519638399535-1b036603ac77?w=1800&q=80");
/* ══════════════════════════════════════════════════════════ */
background-size: cover;
background-position: center;
will-change: transform;
}

.page-hero-content {
position: relative;
}

.page-hero-content .breadcrumb {
font-size: .7rem;
letter-spacing: .35em;
text-transform: uppercase;
color: var(--clr-accent1);
margin-bottom: .5rem;
}

.page-hero-content h1 {
font-family: var(--font-display);
font-size: clamp(3rem, 7vw, 6.5rem);
letter-spacing: .04em;
line-height: .95;
}

/* ── SHARED SECTION ── */
.section {
padding: 6rem 2rem;
max-width: 1200px;
margin: 0 auto;
}

.section-label {
font-size: .7rem;
letter-spacing: .4em;
text-transform: uppercase;
color: var(--clr-accent1);
margin-bottom: .6rem;
}

.section-title {
font-family: var(--font-display);
font-size: clamp(2.2rem, 5vw, 4rem);
letter-spacing: .04em;
margin-bottom: 3rem;
}

/* ── SERVICES LIST ── */
.services-list {
display: flex;
flex-direction: column;
gap: 2px;
}

.svc-row {
display: grid;
grid-template-columns: 80px 1fr auto;
align-items: center;
gap: 2rem;
background: var(--clr-surface);
border: 1px solid var(--clr-border);
padding: 2rem 2.4rem;
position: relative;
overflow: hidden;
transition: border-color .3s, transform .25s;
cursor: default;
}

.svc-row::before {
content: '';
position: absolute;
left: 0;
top: 0;
bottom: 0;
width: 3px;
background: linear-gradient(to bottom, var(--clr-accent2), var(--clr-accent1), var(--clr-accent3));
transform: scaleY(0);
transform-origin: bottom;
transition: transform .4s ease;
}

.svc-row:hover {
border-color: var(--clr-accent1);
transform: translateX(6px);
}

.svc-row:hover::before {
transform: scaleY(1);
}

.svc-num {
font-family: var(--font-display);
font-size: 2.8rem;
letter-spacing: .05em;
background: linear-gradient(135deg, var(--clr-accent2), var(--clr-accent1));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
opacity: .5;
transition: opacity .3s;
}

.svc-row:hover .svc-num {
opacity: 1;
}

.svc-body h3 {
font-family: var(--font-display);
font-size: 1.6rem;
letter-spacing: .05em;
margin-bottom: .4rem;
}

.svc-body p {
font-size: .9rem;
line-height: 1.65;
color: var(--clr-muted);
max-width: 640px;
}

/* ── TAGS de categoria ── */
.svc-tags {
display: flex;
flex-wrap: wrap;
gap: .4rem;
justify-content: flex-end;
}

.tag {
padding: .2rem .7rem;
border: 1px solid var(--clr-border);
font-size: .65rem;
letter-spacing: .15em;
text-transform: uppercase;
color: var(--clr-muted);
}

/* ── DETAIL CARDS — pacotes / diferenciais ── */
.detail-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
gap: 1.2rem;
margin-top: 4rem;
}

.detail-card {
background: var(--clr-surface);
border: 1px solid var(--clr-border);
padding: 1.8rem;
transition: border-color .3s;
}

.detail-card:hover {
border-color: var(--clr-accent3);
}

.detail-card .dc-icon {
font-size: 1.8rem;
margin-bottom: .8rem;
display: block;
}

.detail-card h4 {
font-family: var(--font-display);
font-size: 1.2rem;
letter-spacing: .05em;
margin-bottom: .4rem;
}

.detail-card p {
font-size: .85rem;
line-height: 1.6;
color: var(--clr-muted);
}

/* ── CTA STRIP ── */
.cta-strip {
background: linear-gradient(135deg, rgba(0, 114, 255, .12), rgba(0, 198, 255, .06));
border-top: 1px solid var(--clr-border);
border-bottom: 1px solid var(--clr-border);
padding: 5rem 2rem;
text-align: center;
}

.cta-strip h2 {
font-family: var(--font-display);
font-size: clamp(2rem, 4vw, 3.5rem);
margin-bottom: 1rem;
}

.cta-strip p {
color: var(--clr-muted);
max-width: 480px;
margin: 0 auto 2rem;
font-size: .95rem;
line-height: 1.7;
}

.btn-primary {
display: inline-block;
padding: .75rem 2.4rem;
border: 1.5px solid var(--clr-accent1);
color: var(--clr-accent1);
font-family: var(--font-body);
font-weight: 600;
font-size: .9rem;
letter-spacing: .15em;
text-transform: uppercase;
text-decoration: none;
position: relative;
overflow: hidden;
transition: color .3s;
}

.btn-primary::before {
content: '';
position: absolute;
inset: 0;
background: var(--clr-accent1);
transform: scaleX(0);
transform-origin: left;
transition: transform .35s ease;
z-index: -1;
}

.btn-primary:hover {
color: var(--clr-bg);
}

.btn-primary:hover::before {
transform: scaleX(1);
}

/* ── FOOTER ── */
footer {
padding: 2rem;
text-align: center;
font-size: .75rem;
color: var(--clr-muted);
letter-spacing: .1em;
border-top: 1px solid var(--clr-border);
}

/* ── REVEAL ── */
@keyframes fadeUp {
from {
opacity: 0;
transform: translateY(28px);
}

to {
opacity: 1;
transform: translateY(0);
}
}

.reveal {
opacity: 0;
transform: translateY(28px);
transition: opacity .7s ease, transform .7s ease;
}

.reveal.visible {
opacity: 1;
transform: translateY(0);
}

@media (max-width: 900px) {
nav {
padding: 1rem 1.5rem;
}

.nav-links {
display: none;
}

.page-hero {
padding: 0 1.5rem 2.5rem;
}

.svc-row {
grid-template-columns: 60px 1fr;
}

.svc-tags {
display: none;
}
}
</style>
</head>

<body>

    <nav id="navbar">
        <a href="/home"><img src="IMG/Logo_Empresa.png" alt="TechTake Audiovisual" class="nav-logo" /></a>
        <ul class="nav-links">
