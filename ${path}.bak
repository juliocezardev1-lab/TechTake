    <!-- ═══════════════════════════════════════════════════
       LISTA DE SERVIÇOS
       ───────────────────────────────────────────────────
       Para ADICIONAR um serviço: duplique um bloco .svc-row
       Para EDITAR: altere o <h3>, o <p> e as .tag abaixo
  ═══════════════════════════════════════════════════ -->
    <div class="section">
        <p class="section-label reveal">O que oferecemos</p>
        <h2 class="section-title reveal">Serviços</h2>

        <div class="services-list">

            <!-- SERVIÇO 1 ─────────────────────────────────── -->
