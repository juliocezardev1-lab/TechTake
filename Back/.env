# Variáveis de ambiente para DESENVOLVIMENTO LOCAL
# Este arquivo NÃO deve ser enviado ao GitHub (.gitignore já cuida disso)

# Porta em que o servidor roda localmente
PORT=3000

# Ambiente de execução
NODE_ENV=development

# Chave secreta para gerar tokens JWT — pode ser qualquer texto longo em desenvolvimento
JWT_SECRET=chave-local-desenvolvimento-qualquer-texto-longo

# Em desenvolvimento, o CORS aceita localhost automaticamente
# Deixe esta variável vazia ou não defina ela
# FRONTEND_ORIGIN=
