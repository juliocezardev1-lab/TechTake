# ============================================================
# .env — Variáveis de ambiente
# Leia INSTRUCOES_LOCALHOST.txt para saber o que alterar ao trocar de ambiente
# ============================================================

# ── MODO ATUAL: LOCALHOST (desenvolvimento local) ────────────
# Para rodar localmente, mantenha NODE_ENV=development (linha 11)
# Para fazer deploy no Render, troque para NODE_ENV=production (linha 12)

# Porta em que o servidor roda localmente
PORT=3000

# LOCALHOST → mantenha esta linha ativa:
NODE_ENV=development
# PRODUÇÃO (Render) → comente a linha acima e descomente a abaixo:
# NODE_ENV=production

# Chave secreta para gerar tokens JWT — pode ser qualquer texto longo em desenvolvimento
JWT_SECRET=chave-local-desenvolvimento-qualquer-texto-longo

# Em desenvolvimento, o CORS aceita localhost automaticamente
# Em produção, descomente e coloque a URL real do seu site no Netlify:
# FRONTEND_ORIGIN=https://seu-site.netlify.app
